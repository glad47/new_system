<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.api.mapper.BizD365CacheMapper">

    <resultMap type="com.ruoyi.api.domain.BizD365Cache" id="CacheResult">
        <id property="cacheId" column="cache_id"/>
        <result property="endpointName" column="endpoint_name"/>
        <result property="endpointLabel" column="endpoint_label"/>
        <result property="extraParams" column="extra_params"/>
        <result property="cachedData" column="cached_data"/>
        <result property="ttlHours" column="ttl_hours"/>
        <result property="lastSyncTime" column="last_sync_time"/>
        <result property="nextSyncTime" column="next_sync_time"/>
        <result property="syncStatus" column="sync_status"/>
        <result property="errorMessage" column="error_message"/>
        <result property="recordCount" column="record_count"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- List WITHOUT cached_data (for table display — avoid sending megabytes) -->
    <select id="selectList" parameterType="com.ruoyi.api.domain.BizD365Cache" resultMap="CacheResult">
        select cache_id, endpoint_name, endpoint_label, extra_params, ttl_hours,
               last_sync_time, next_sync_time, sync_status, error_message, record_count,
               status, create_by, create_time, update_by, update_time
        from biz_d365_cache
        <where>
            <if test="endpointName != null and endpointName != ''">AND endpoint_name like concat('%',#{endpointName},'%')</if>
            <if test="syncStatus != null and syncStatus != ''">AND sync_status = #{syncStatus}</if>
        </where>
        order by cache_id
    </select>

    <select id="selectById" parameterType="Long" resultMap="CacheResult">
        select * from biz_d365_cache where cache_id = #{cacheId}
    </select>

    <select id="selectByEndpoint" resultMap="CacheResult">
        select * from biz_d365_cache
        where endpoint_name = #{param1}
        and (extra_params = #{param2} or (#{param2} is null and extra_params is null))
        limit 1
    </select>

    <insert id="insert" parameterType="com.ruoyi.api.domain.BizD365Cache" useGeneratedKeys="true" keyProperty="cacheId">
        insert into biz_d365_cache (endpoint_name,endpoint_label,extra_params,cached_data,ttl_hours,
            last_sync_time,next_sync_time,sync_status,error_message,record_count,status,create_by,create_time)
        values (#{endpointName},#{endpointLabel},#{extraParams},#{cachedData},#{ttlHours},
            #{lastSyncTime},#{nextSyncTime},#{syncStatus},#{errorMessage},#{recordCount},#{status},#{createBy},sysdate())
    </insert>

    <update id="update" parameterType="com.ruoyi.api.domain.BizD365Cache">
        update biz_d365_cache
        <trim prefix="SET" suffixOverrides=",">
            <if test="endpointLabel != null">endpoint_label=#{endpointLabel},</if>
            <if test="extraParams != null">extra_params=#{extraParams},</if>
            <if test="cachedData != null">cached_data=#{cachedData},</if>
            <if test="ttlHours != null">ttl_hours=#{ttlHours},</if>
            <if test="lastSyncTime != null">last_sync_time=#{lastSyncTime},</if>
            <if test="nextSyncTime != null">next_sync_time=#{nextSyncTime},</if>
            <if test="syncStatus != null">sync_status=#{syncStatus},</if>
            <if test="errorMessage != null">error_message=#{errorMessage},</if>
            <if test="recordCount != null">record_count=#{recordCount},</if>
            <if test="updateBy != null">update_by=#{updateBy},</if>
            update_time=sysdate(),
        </trim>
        where cache_id = #{cacheId}
    </update>

    <delete id="deleteByIds" parameterType="String">
        delete from biz_d365_cache where cache_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
