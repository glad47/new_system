<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.api.mapper.BizProductNumberSeqMapper">

    <resultMap type="com.ruoyi.api.domain.BizProductNumberSeq" id="SeqResult">
        <id     property="seqId"        column="seq_id"        />
        <result property="prefix"       column="prefix"        />
        <result property="currentValue" column="current_value" />
        <result property="incrementBy"  column="increment_by"  />
        <result property="minValue"     column="min_value"     />
        <result property="maxValue"     column="max_value"     />
        <result property="padLength"    column="pad_length"    />
        <result property="description"  column="description"   />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <sql id="selectVo">
        select seq_id, prefix, current_value, increment_by, min_value, max_value,
               pad_length, description, status, create_by, create_time, update_by, update_time
        from biz_product_number_seq
    </sql>

    <select id="selectBizProductNumberSeqList" parameterType="com.ruoyi.api.domain.BizProductNumberSeq" resultMap="SeqResult">
        <include refid="selectVo"/>
        <where>
            <if test="prefix != null and prefix != ''">AND prefix like concat('%', #{prefix}, '%')</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by seq_id asc
    </select>

    <select id="selectBizProductNumberSeqById" parameterType="Long" resultMap="SeqResult">
        <include refid="selectVo"/>
        where seq_id = #{seqId}
    </select>

    <insert id="insertBizProductNumberSeq" parameterType="com.ruoyi.api.domain.BizProductNumberSeq" useGeneratedKeys="true" keyProperty="seqId">
        insert into biz_product_number_seq (prefix, current_value, increment_by, min_value, max_value, pad_length, description, status, create_by, create_time)
        values (#{prefix}, #{currentValue}, #{incrementBy}, #{minValue}, #{maxValue}, #{padLength}, #{description}, #{status}, #{createBy}, sysdate())
    </insert>

    <update id="updateBizProductNumberSeq" parameterType="com.ruoyi.api.domain.BizProductNumberSeq">
        update biz_product_number_seq
        <trim prefix="SET" suffixOverrides=",">
            <if test="prefix != null">prefix = #{prefix},</if>
            <if test="currentValue != null">current_value = #{currentValue},</if>
            <if test="incrementBy != null">increment_by = #{incrementBy},</if>
            <if test="minValue != null">min_value = #{minValue},</if>
            <if test="maxValue != null">max_value = #{maxValue},</if>
            <if test="padLength != null">pad_length = #{padLength},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate(),
        </trim>
        where seq_id = #{seqId}
    </update>

    <update id="incrementCurrentValue" parameterType="Long">
        update biz_product_number_seq
        set current_value = current_value + increment_by,
            update_time = sysdate()
        where seq_id = #{seqId}
    </update>

    <delete id="deleteBizProductNumberSeqByIds" parameterType="String">
        delete from biz_product_number_seq where seq_id in
        <foreach item="seqId" collection="array" open="(" separator="," close=")">
            #{seqId}
        </foreach>
    </delete>

</mapper>
