<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.api.mapper.BizPriceTemplateMapper">

    <resultMap type="com.ruoyi.api.domain.BizPriceTemplate" id="BizPriceTemplateResult">
        <id     property="priceTemplateId"   column="price_template_id"   />
        <result property="priceTemplateName" column="price_template_name" />
        <result property="size"              column="size"                />
        <result property="status"            column="status"              />
        <result property="delFlag"           column="del_flag"            />
        <result property="isDefault"         column="is_default"          />
        <result property="createBy"          column="create_by"           />
        <result property="createTime"        column="create_time"         />
        <result property="updateBy"          column="update_by"           />
        <result property="updateTime"        column="update_time"         />
        <result property="remark"            column="remark"              />
    </resultMap>

    <sql id="selectBizPriceTemplateVo">
        select price_template_id, price_template_name, size, status, del_flag, is_default,
               create_by, create_time, update_by, update_time, remark
        from biz_price_template
    </sql>

    <!-- Paginated list with optional filters -->
    <select id="selectBizPriceTemplateList" parameterType="com.ruoyi.api.domain.BizPriceTemplate" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        <where>
            del_flag = '0'
            <if test="priceTemplateName != null and priceTemplateName != ''">
                AND price_template_name like concat('%', #{priceTemplateName}, '%')
            </if>
            <if test="size != null and size != ''">
                AND size like concat('%', #{size}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by is_default desc, create_time desc
    </select>

    <!-- All active templates for dropdowns -->
    <select id="selectAllActivePriceTemplates" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        where del_flag = '0' and status = '0'
        order by is_default desc, price_template_name
    </select>

    <!-- Single record by ID -->
    <select id="selectBizPriceTemplateById" parameterType="Long" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        where price_template_id = #{priceTemplateId} and del_flag = '0'
    </select>

    <!-- Get the current default template -->
    <select id="selectDefaultPriceTemplate" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        where del_flag = '0' and is_default = '1'
        limit 1
    </select>

    <!-- Uniqueness check -->
    <select id="checkPriceTemplateNameUnique" parameterType="String" resultMap="BizPriceTemplateResult">
        select price_template_id, price_template_name from biz_price_template
        where price_template_name = #{priceTemplateName} and del_flag = '0'
        limit 1
    </select>

    <!-- Insert — is_default always written, defaults to '0' if null -->
    <insert id="insertBizPriceTemplate" parameterType="com.ruoyi.api.domain.BizPriceTemplate" useGeneratedKeys="true" keyProperty="priceTemplateId">
        insert into biz_price_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">price_template_name,</if>
            <if test="size != null">size,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            is_default,
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">#{priceTemplateName},</if>
            <if test="size != null">#{size},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <choose>
                <when test="isDefault != null">#{isDefault},</when>
                <otherwise>'0',</otherwise>
            </choose>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <!-- Update — is_default only updated when explicitly provided -->
    <update id="updateBizPriceTemplate" parameterType="com.ruoyi.api.domain.BizPriceTemplate">
        update biz_price_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">price_template_name = #{priceTemplateName},</if>
            <if test="size != null">size = #{size},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where price_template_id = #{priceTemplateId}
    </update>

    <!-- Set-default step 1: clear all existing defaults -->
    <update id="clearAllDefaults">
        update biz_price_template
        set is_default = '0'
        where del_flag = '0'
          and is_default = '1'
    </update>

    <!-- Set-default step 2: mark the chosen template -->
    <update id="setDefaultById" parameterType="Long">
        update biz_price_template
        set is_default = '1'
        where price_template_id = #{priceTemplateId}
          and del_flag = '0'
    </update>

    <!-- Soft delete by single ID -->
    <update id="deleteBizPriceTemplateById" parameterType="Long">
        update biz_price_template set del_flag = '2' where price_template_id = #{priceTemplateId}
    </update>

    <!-- Soft delete by multiple IDs -->
    <update id="deleteBizPriceTemplateByIds" parameterType="String">
        update biz_price_template set del_flag = '2' where price_template_id in
        <foreach item="priceTemplateId" collection="array" open="(" separator="," close=")">
            #{priceTemplateId}
        </foreach>
    </update>

</mapper>
