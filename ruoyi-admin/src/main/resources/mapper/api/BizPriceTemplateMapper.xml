<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.api.mapper.BizPriceTemplateMapper">

    <resultMap type="com.ruoyi.api.domain.BizPriceTemplate" id="BizPriceTemplateResult">
        <id     property="priceTemplateId"    column="price_template_id"    />
        <result property="priceTemplateName"  column="price_template_name"  />
        <result property="size"               column="size"                 />
        <result property="widthMm"            column="width_mm"             />
        <result property="heightMm"           column="height_mm"            />
        <result property="status"             column="status"               />
        <result property="isDefault"          column="is_default"           />
        <result property="delFlag"            column="del_flag"             />
        <result property="productNameOverride" column="product_name_override" />
        <result property="nameMaxChars"       column="name_max_chars"       />
        <result property="createBy"           column="create_by"            />
        <result property="createTime"         column="create_time"          />
        <result property="updateBy"           column="update_by"            />
        <result property="updateTime"         column="update_time"          />
        <result property="remark"             column="remark"               />
    </resultMap>

    <sql id="selectBizPriceTemplateVo">
        select price_template_id, price_template_name, size, width_mm, height_mm,
               status, is_default, del_flag,
               product_name_override, name_max_chars,
               create_by, create_time, update_by, update_time, remark
        from biz_price_template
    </sql>

    <select id="selectBizPriceTemplateList" parameterType="com.ruoyi.api.domain.BizPriceTemplate" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        <where>
            del_flag = '0'
            <if test="priceTemplateName != null and priceTemplateName != ''">
                AND price_template_name LIKE CONCAT('%', #{priceTemplateName}, '%')
            </if>
            <if test="size != null and size != ''">AND size = #{size}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY price_template_id ASC
    </select>

    <select id="selectBizPriceTemplateById" parameterType="Long" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        where price_template_id = #{priceTemplateId} and del_flag = '0'
    </select>

    <select id="selectAllBizPriceTemplates" resultMap="BizPriceTemplateResult">
        <include refid="selectBizPriceTemplateVo"/>
        where del_flag = '0'
        order by price_template_id asc
    </select>

    <insert id="insertBizPriceTemplate" parameterType="com.ruoyi.api.domain.BizPriceTemplate" useGeneratedKeys="true" keyProperty="priceTemplateId">
        insert into biz_price_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">price_template_name,</if>
            <if test="size != null">size,</if>
            <if test="widthMm != null">width_mm,</if>
            <if test="heightMm != null">height_mm,</if>
            <if test="status != null">status,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="productNameOverride != null">product_name_override,</if>
            <if test="nameMaxChars != null">name_max_chars,</if>
            del_flag,
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">#{priceTemplateName},</if>
            <if test="size != null">#{size},</if>
            <if test="widthMm != null">#{widthMm},</if>
            <if test="heightMm != null">#{heightMm},</if>
            <if test="status != null">#{status},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="productNameOverride != null">#{productNameOverride},</if>
            <if test="nameMaxChars != null">#{nameMaxChars},</if>
            '0',
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateBizPriceTemplate" parameterType="com.ruoyi.api.domain.BizPriceTemplate">
        update biz_price_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="priceTemplateName != null and priceTemplateName != ''">price_template_name = #{priceTemplateName},</if>
            <if test="size != null">size = #{size},</if>
            <if test="widthMm != null">width_mm = #{widthMm},</if>
            <if test="heightMm != null">height_mm = #{heightMm},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            product_name_override = #{productNameOverride},
            name_max_chars = #{nameMaxChars},
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where price_template_id = #{priceTemplateId}
    </update>

    <update id="deleteBizPriceTemplateById" parameterType="Long">
        update biz_price_template set del_flag = '2' where price_template_id = #{priceTemplateId}
    </update>

    <update id="deleteBizPriceTemplateByIds" parameterType="String">
        update biz_price_template set del_flag = '2' where price_template_id in
        <foreach item="priceTemplateId" collection="array" open="(" separator="," close=")">
            #{priceTemplateId}
        </foreach>
    </update>

    <update id="clearDefaultForOthers" parameterType="Long">
        update biz_price_template set is_default = '0'
        where price_template_id != #{priceTemplateId} and del_flag = '0'
    </update>

</mapper>
